# ==============================================
# FITAI — ENVIRONMENT VARIABLES
# Copy file này, đổi tên thành .env.local để test local
# Trên Vercel: paste từng dòng vào Settings → Environment Variables
# ==============================================

# 1. ANTHROPIC (Claude AI)
# Lấy tại: platform.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxx

# 2. STRIPE (Thu tiền)
# Lấy tại: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxx

# Price ID - lấy tại: Stripe → Products → FitAI Pro
STRIPE_PRICE_ANNUAL=price_xxxxxxxxxxxxxxxxxx
STRIPE_PRICE_MONTHLY=price_xxxxxxxxxxxxxxxxxx

# Webhook secret - lấy tại: Stripe → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxx

# 3. URL của app (điền domain Vercel của bạn)
NEXT_PUBLIC_BASE_URL=https://fitai.vercel.app
